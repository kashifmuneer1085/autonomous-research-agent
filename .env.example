# ═══════════════════════════════════════════════════════════════════
#  Autonomous AI Research Agent — Environment Variables
#  FREE STACK: Groq LLM + DuckDuckGo Search (zero cost, no credit card)
#
#  Copy this file to .env and fill in your Groq API key.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── LLM — Groq (FREE) ───────────────────────────────────────────────
# 1. Go to https://console.groq.com
# 2. Sign up (free, no credit card)
# 3. Click API Keys → Create API Key → paste below
GROQ_API_KEY=your_groq_api_key_here

# Model selection (both use the same free model)
# Options: llama-3.3-70b-versatile | llama-3.1-8b-instant | mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_STRONG=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=4096

# ── Search — DuckDuckGo (FREE, NO KEY NEEDED) ───────────────────────
# Nothing to configure — works out of the box!
MAX_SEARCH_RESULTS=10
NUM_SEARCH_QUERIES=3

# ── Scraping ─────────────────────────────────────────────────────────
SCRAPER_TIMEOUT_S=20
MAX_CONTENT_LENGTH=15000
SCRAPER_CONCURRENCY=4

# ── Content Processing ───────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=10
DEDUP_THRESHOLD=0.85

# ── Agent ────────────────────────────────────────────────────────────
MAX_RETRIES=3
MAX_SOURCES=8

# ── Google Integration (100% OPTIONAL) ──────────────────────────────
# Skip this entirely — reports are auto-saved to the data/ folder.
# Only fill in if you want Google Docs/Sheets export.
# See docs/google_integration.md for setup instructions.
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GOOGLE_DRIVE_FOLDER_ID=

# ── Storage & Logging ────────────────────────────────────────────────
DATA_DIR=data
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR

# ── API Server ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000